<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.demo.HelloController"
      spacing="15" alignment="TOP_LEFT"
      style="-fx-padding: 20; -fx-background-color: #1e1e1e;">

    <Label text="AutoRepo — Générateur GitHub"
           style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" />

    <!-- Nom du repo -->
    <HBox spacing="10">
        <Label text="Nom du repo :" style="-fx-text-fill: white;" />
        <TextField fx:id="repoNameField" promptText="Nom du projet" />
    </HBox>

    <!-- Description -->
    <HBox spacing="10">
        <Label text="Description :" style="-fx-text-fill: white;" />
        <TextField fx:id="descriptionField" promptText="Description du projet" />
    </HBox>

    <!-- README -->
    <HBox spacing="10">
        <Label text="Créer README ?" style="-fx-text-fill: white;" />
        <TextField fx:id="readmeField" promptText="oui / non" />
    </HBox>

    <!-- Bouton -->
    <Button text="Créer le projet"
            onAction="#onCreateProject"
            style="-fx-background-color: #3c3c3c; -fx-text-fill: white; -fx-padding: 10 20;" />

</VBox>
